generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("POSTGRES_PRISMA_URL_PRISMA_DATABASE_URL")
  directUrl = env("POSTGRES_PRISMA_URL_POSTGRES_URL")
}

model Photograph {
  id             String   @id @default(cuid())
  title          String
  description    String?
  section        String
  imageUrl       String
  imageKitFileId String
  width          Int?
  height         Int?
  featured       Boolean  @default(false)
  uploadedAt     DateTime @default(now())
  eventDate      DateTime?
  tags           String?
}

model Section {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  author    String
  role      String
  text      String
  avatar    String?
  rating    Int      @default(5)
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
